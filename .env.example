# NSCC Fantasy — environment template. Copy to `.env` (or `.env.local`) and fill in.
# NEVER commit real keys. `.env*` (except this example) belongs in .gitignore.

# Supabase project — from Project Settings → API.
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anon (public) key: safe to ship to the browser. RLS (migration 0004) is what protects
# the data — the anon role reads NOTHING (D17), so this key alone exposes no club data.
SUPABASE_ANON_KEY=<your-anon-public-key>

# Service-role key: FULL bypass of RLS. Used ONLY by the trusted backend / recompute
# (writeDerived) — NEVER shipped to the browser, NEVER committed. Keep it in your secret
# store (Vercel/Netlify env, Supabase Edge secret, etc.). Named here for completeness;
# this repo/session never requests its value.
SUPABASE_SERVICE_ROLE_KEY=<set-in-your-secret-store-do-not-commit>
