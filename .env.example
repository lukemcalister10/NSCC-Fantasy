# NSCC Fantasy — environment template. Copy to `.env` (or `.env.local`) and adjust.
# NEVER commit real secrets. `.env*` (except this example) belongs in .gitignore.

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (Vite) — only `VITE_`-prefixed vars are exposed to the browser bundle.
# Both values below are PUBLIC by design (RLS/migration 0004 does authorization;
# the anon/publishable key reads NOTHING when logged out, D17). The defaults point
# at the live project so `npm run dev` works out of the box.
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://gibdcruufikkhgpswrpa.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_0C2mIzmhtZtK24_vFEtjHA_nR5epg8j

# ─────────────────────────────────────────────────────────────────────────────
# SEED GENERATOR (Node, operator-only) — NOT part of the browser bundle.
# `npm run seed:generate` needs NO secrets: it runs `recomputeSeason` in-process and
# writes supabase/seed/seed_raw.sql + seed_derived.sql, which the operator pastes
# into the Supabase SQL editor (see VERCEL_DEPLOY.md). No DB connection required.
# ─────────────────────────────────────────────────────────────────────────────

# Legacy names kept for the SUPABASE_LIVE_VERIFY runbook / any future pg-based tool.
# The service-role key FULLY bypasses RLS: server-side only, never shipped, never
# committed. This repo/session never requests its value.
SUPABASE_URL=https://gibdcruufikkhgpswrpa.supabase.co
SUPABASE_ANON_KEY=sb_publishable_0C2mIzmhtZtK24_vFEtjHA_nR5epg8j
SUPABASE_SERVICE_ROLE_KEY=<set-in-your-secret-store-do-not-commit>
